# Banco de dados SQLite
DATABASE_URL="file:./dev.db"

# JWT — Troque o segredo em produção!
JWT_SECRET="seu-segredo-jwt-super-secreto-troque-em-producao"
JWT_EXPIRES_IN="8h"

# Credenciais do administrador (altere antes de fazer deploy)
ADMIN_EMAIL="admin@minicrm.com"
ADMIN_PASSWORD="Admin@123"

# Servidor
PORT=3001

# CORS — URL do frontend
CORS_ORIGIN="http://localhost:5173"

# Ambiente
NODE_ENV="development"
